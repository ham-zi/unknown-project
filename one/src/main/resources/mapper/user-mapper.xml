<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
  <mapper namespace="com.api.one.member.model.dao.UserMapper">
  
  	<select id="checkUserId" resultType="_int">
  		SELECT 
  		       COUNT(*)
  		  FROM 
  		       ONE_USER
  		 WHERE 
  		       USER_ID = #{userId}
  	</select>
  	
  	<insert id="signUp">
		INSERT	
	      INTO 
	           ONE_USER
	    VALUES 
	          (
			   #{userId}
			 , #{userPwd}
			 , #{userName}
			 , #{email}
			 , SYSDATE
			 , 'Y'
			 , 'ROLE_USER'
			  )
  	
  	</insert>
  
  
  	
  
  
  
  </mapper>